{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ChatLLM API (uvicorn)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "backend.main:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": true,
      "linux": {
        "python": "${workspaceFolder}/.venv/bin/python"
      },
      "osx": {
        "python": "${workspaceFolder}/.venv/bin/python"
      },
      "windows": {
        "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Uvicorn running on (https?://\\S+)",
        "uriFormat": "%s"
      }
    }
  ]
}
